{
  "codeLens.enable": true,
  "coc.preferences.formatOnSaveFiletypes": [
    "javascript",
    "html",
    "css",
    "json"
  ],
  "languageserver": {
    "golang": {
      "command": "gopls",
      "rootPatterns": ["go.mod"],
      "disableWorkspaceFolders": true,
      "filetypes": ["go"]
    }
  }
}
