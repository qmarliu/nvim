{
    "codeLens.enable": true,
    "snippets.ultisnips.usePythonx": false,
    "coc.preferences.formatOnSaveFiletypes": [
        "javascript",
        "html",
        "css",
        "json"
    ],
    "languageserver": {
        "golang": {
            "command": "gopls",
            "rootPatterns": [
                "go.mod"
            ],
            "filetypes": [
                "go"
            ]
        }
    }
}
